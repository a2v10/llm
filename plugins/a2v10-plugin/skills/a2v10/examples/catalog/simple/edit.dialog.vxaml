<!-- Edit Sample -->
<Dialog xmlns="clr-namespace:A2v10.Xaml;assembly=A2v10.Xaml"
		Title="{Bind Sample.Id, Format='@[Sample] [{0}]'}" Overflow="True">
	<Dialog.Buttons>
		<Button Content="@[SaveAndClose]" Command="{BindCmd SaveAndClose, ValidRequired=True}" Style="Primary"/>
		<Button Content="@[Cancel]" Command="{BindCmd Close}"/>
	</Dialog.Buttons>
	<Grid>
		<TextBox Label="@[Name]" Value="{Bind Sample.Name}" Bold="True" TabIndex="1"/>
		<TextBox Label="@[Memo]" Value="{Bind Sample.Memo}" Multiline="True" Rows="3"/>
	</Grid>
</Dialog>

