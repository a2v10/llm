{
  "ConnectionStrings": {
    "Default": "Server=localhost;Database=^AppName^;Trusted_Connection=True;MultipleActiveResultSets=true;Encrypt=False"
  },
    "Logging": {
        "LogLevel": {
            "Default": "Information",
            "Microsoft.AspNetCore": "Warning"
        }
    },
    "AllowedHosts": "*",
    "Data": {
        "MetadataCache": false,
        "CommandTimeout": "00:00:30"
    },
  "Application": {
    "AppId": "^AppName^",
    "Theme": "tabbed.light",
    "Layout": "tabbed",
    "Environment": {
      "Watch": true,
      "Stage": "debug"
    },
    "Modules": {
      "Main": {
        "Default": true,
        "Path": "../MainApp"
      }
    }
  },
  "Identity": {
    "CookiePrefix": "^AppName^.^Year^"
  }
}
